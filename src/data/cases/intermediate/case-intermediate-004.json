        "git cherry-pick --no-edit abc1234": [
          "[main d5a8842] Add verified witness transcript",
          " Date: Tue Mar 12 20:10:00 2026 +0000",
          " 1 file changed, 12 insertions(+)"
        ]
      },
      "hint": "Apply a specific commit to current branch",
      "points": 40
    },
    {
      "instruction": "If there's a conflict, abort the cherry-pick operation.",
      "narrative": "Something went wrong. Abort and reassess.",
      "expected_commands": [
        "git cherry-pick --abort"
      ],
      "hint": "Cancel an in-progress cherry-pick",
      "points": 30
    },
    {
      "instruction": "View the log to confirm the commit was applied.",
