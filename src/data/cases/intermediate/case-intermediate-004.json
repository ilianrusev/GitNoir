{
  "id": "intermediate-case-004",
  "title": "THE CHERRY PICKER",
  "description": "Extract specific commits from one branch to another. Surgical precision required.",
  "difficulty": "Intermediate",
  "total_points": 160,
  "created_at": "2026-03-12",
  "story_intro": "Two separate investigations had been running in parallel. One team found crucial evidence, but their branch was a mess.\n\n'I only need that ONE commit,' I muttered. 'Not the whole chaotic branch.'\n\nCherry-pick. Take exactly what you need, leave the rest behind.",
  "steps": [
    {
      "instruction": "View the log of the 'chaotic-investigation' branch to find the good commit.",
      "narrative": "First, identify exactly which commit contains the evidence I need.",
      "expected_commands": [
        "git log chaotic-investigation",
        "git log chaotic-investigation --oneline",
        "git log --oneline chaotic-investigation"
      ],
      "terminal_output_by_command": {
        "git log chaotic-investigation": [
          "commit abc1234 (chaotic-investigation)",
          "Author: Analyst <analyst@agency.local>",
          "Date: Tue Mar 12 20:10:00 2026 +0000",
          "",
          "    Add verified witness transcript",
          "",
          "commit f80d991",
          "Author: Analyst <analyst@agency.local>",
          "Date: Tue Mar 12 19:48:00 2026 +0000",
          "",
          "    Temporary debug dump"
        ],
        "git log chaotic-investigation --oneline": [
          "abc1234 Add verified witness transcript",
          "f80d991 Temporary debug dump",
          "9e0bc44 Merge branch 'scratch'"
        ],
        "git log --oneline chaotic-investigation": [
          "abc1234 Add verified witness transcript",
          "f80d991 Temporary debug dump",
          "9e0bc44 Merge branch 'scratch'"
        ]
      },
      "hint": "View commits on another branch",
      "points": 30
    },
    {
      "instruction": "Make sure you're on the main branch.",
      "narrative": "Cherry-picking brings commits TO your current branch. Get positioned.",
      "expected_commands": [
        "git checkout main",
        "git switch main",
        "git checkout refs/heads/main"
      ],
      "terminal_output_by_command": {
        "git checkout main": [
          "Switched to branch 'main'"
        ],
        "git switch main": [
          "Switched to branch 'main'"
        ],
        "git checkout refs/heads/main": [
          "Switched to branch 'main'"
        ]
      },
      "hint": "Switch to main branch",
      "points": 25
    },
    {
      "instruction": "Cherry-pick the commit with hash 'abc1234'.",
      "narrative": "Extract that single commit. Surgical precision.",
      "expected_commands": [
        "git cherry-pick abc1234",
        "git cherry-pick --no-edit abc1234"
      ],
      "terminal_output_by_command": {
        "git cherry-pick abc1234": [
          "[main d5a8842] Add verified witness transcript",
          " Date: Tue Mar 12 20:10:00 2026 +0000",
