{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://git-noir.local/schemas/case.schema.json",
  "title": "Git Noir Case",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "description",
    "difficulty",
    "unlock_cost",
    "total_points",
    "story_intro",
    "steps"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^case-[0-9]{3}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "difficulty": {
      "type": "string",
      "enum": ["Beginner", "Intermediate", "Advanced"]
    },
    "unlock_cost": {
      "type": "integer",
      "minimum": 0
    },
    "total_points": {
      "type": "integer",
      "minimum": 1
    },
    "story_intro": {
      "type": "string",
      "minLength": 1
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "./step.schema.json"
      }
    }
  }
}
