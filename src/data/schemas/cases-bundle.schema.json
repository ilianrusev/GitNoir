{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://git-noir.local/schemas/cases-bundle.schema.json",
  "title": "Git Noir Cases Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": ["cases"],
  "properties": {
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "./case.schema.json"
      }
    }
  }
}
