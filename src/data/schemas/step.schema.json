{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://git-noir.local/schemas/step.schema.json",
  "title": "Git Noir Case Step",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "instruction",
    "narrative",
    "expected_commands",
    "hint",
    "points"
  ],
  "properties": {
    "instruction": {
      "type": "string",
      "minLength": 1
    },
    "narrative": {
      "type": "string",
      "minLength": 1
    },
    "expected_commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "hint": {
      "type": "string",
      "minLength": 1
    },
    "points": {
      "type": "integer",
      "minimum": 1
    },
    "terminal_output_by_command": {
      "description": "Optional command-specific simulated output keyed by expected command. Each value can be a string or array of output lines.",
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          {
            "type": "string"
          },
          {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        ]
      }
    }
  }
}
